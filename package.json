{
  "name": "virtual-table",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.30.3",
  "scripts": {
    "dev": "turbo run dev --parallel",
    "build": "turbo run build",
    "test": "turbo run test && cargo test --manifest-path backend/Cargo.toml",
    "lint": "turbo run lint && cargo fmt --manifest-path backend/Cargo.toml -- --check && cargo clippy --manifest-path backend/Cargo.toml --all-targets -- -D warnings",
    "typecheck": "turbo run typecheck",
    "compose:up": "docker compose -f infrastructure/docker-compose.yml up -d --build",
    "compose:down": "docker compose -f infrastructure/docker-compose.yml down"
  },
  "pnpm": {
    "overrides": {
      "undici": "7.24.0",
      "flatted": "3.4.2",
      "picomatch@^4.0.0": "4.0.4"
    },
    "reviewNotes": {
      "undici": {
        "mitigates": [
          "CVE-2026-1525",
          "CVE-2026-1528",
          "CVE-2026-2581",
          "CVE-2026-1527",
          "CVE-2026-2229",
          "CVE-2026-1526"
        ],
        "reference": "https://github.com/nodejs/undici/releases/tag/v7.24.0",
        "note": "Pinned for the current audit cleanup. Undici v7.24.2 is available for reviewer verification or follow-up adoption if acceptable."
      }
    }
  },
  "devDependencies": {
    "turbo": "^2.8.21"
  }
}
