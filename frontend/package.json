{
  "name": "frontend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite dev --port 3000",
    "build": "vite build && cp dist/client/_shell.html dist/client/index.html",
    "start": "serve -s dist/client -l 3000",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.node.json",
    "test": "vitest run",
    "clients:start": "bash ./scripts/multi-clients.sh start",
    "clients:stop": "bash ./scripts/multi-clients.sh stop",
    "clients:list": "bash ./scripts/multi-clients.sh list",
    "test:e2e": "pnpm --dir .. compose:up && playwright test -c playwright.config.ts",
    "test:e2e:headed": "pnpm --dir .. compose:up && playwright test -c playwright.config.ts --headed",
    "test:e2e:install": "playwright install chromium"
  },
  "dependencies": {
    "@livekit/components-react": "^2.9.20",
    "@tailwindcss/vite": "^4.2.2",
    "@tanstack/react-router": "^1.168.8",
    "@tanstack/react-start": "^1.167.41",
    "@tanstack/router-plugin": "^1.167.22",
    "livekit-client": "^2.18.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "serve": "^14.2.5",
    "tailwindcss": "^4.2.2",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.59.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@types/node": "25.5.2",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "10.2.0",
    "eslint-plugin-react-hooks": "^7.0.0",
    "globals": "^17.4.0",
    "jsdom": "29.0.2",
    "typescript": "6.0.3",
    "typescript-eslint": "^8.58.0",
    "vite": "^8.0.8",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "4.1.2"
  }
}
