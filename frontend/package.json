{
  "name": "frontend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "clients:start": "bash ./scripts/multi-clients.sh start",
    "clients:stop": "bash ./scripts/multi-clients.sh stop",
    "clients:list": "bash ./scripts/multi-clients.sh list",
    "test:e2e": "pnpm --dir .. compose:up && playwright test -c playwright.config.ts",
    "test:e2e:headed": "pnpm --dir .. compose:up && playwright test -c playwright.config.ts --headed",
    "test:e2e:install": "playwright install chromium"
  },
  "dependencies": {
    "@livekit/components-react": "^2.9.20",
    "livekit-client": "^2.17.2",
    "next": "16.1.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@eslint/compat": "2.0.2",
    "@playwright/test": "^1.55.0",
    "@tailwindcss/postcss": "^4.2.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@types/node": "25.3.3",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "autoprefixer": "10.4.27",
    "eslint": "10.0.2",
    "eslint-config-next": "16.1.6",
    "jsdom": "28.1.0",
    "postcss": "8.5.8",
    "tailwindcss": "4.2.1",
    "typescript": "5.9.3",
    "vitest": "4.0.18"
  }
}
