{
  "name": "frontend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite dev --port 3000",
    "build": "vite build && cp dist/client/_shell.html dist/client/index.html",
    "start": "serve -s dist/client -l 3000",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.node.json",
    "test": "vitest run",
    "clients:start": "bash ./scripts/multi-clients.sh start",
    "clients:stop": "bash ./scripts/multi-clients.sh stop",
    "clients:list": "bash ./scripts/multi-clients.sh list",
    "test:e2e": "bash ./scripts/run-e2e.sh",
    "test:e2e:headed": "bash ./scripts/run-e2e.sh --headed",
    "test:e2e:install": "playwright install chromium"
  },
  "dependencies": {
    "@livekit/components-react": "^2.9.21",
    "@tailwindcss/vite": "^4.3.0",
    "@tanstack/react-router": "1.170.10",
    "@tanstack/react-start": "1.168.22",
    "@tanstack/router-plugin": "1.168.16",
    "livekit-client": "^2.19.1",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "serve": "^14.2.5",
    "tailwindcss": "^4.3.0",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.60.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@types/node": "25.9.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "eslint": "10.4.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.6.0",
    "jsdom": "29.0.2",
    "typescript": "6.0.3",
    "typescript-eslint": "^8.60.1",
    "vite": "^8.0.16",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "4.1.8"
  }
}
